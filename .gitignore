# --- Environment ---
.env
.env.local
.env.*.local
firebase-service-account.json
*-firebase-adminsdk-*.json
backend/*.json
!backend/package.json

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# --- Node ---
node_modules/
frontend/node_modules/
frontend/dist/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Logs ---
*.log
npm-debug.log*

# --- ML Models (large files — use Git LFS or keep in repo) ---
# Uncomment below if using Git LFS for models:
# backend/ml/models/*.pkl

# --- OS ---
.DS_Store
desktop.ini
